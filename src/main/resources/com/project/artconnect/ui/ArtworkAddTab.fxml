<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtworkAddTabController">
    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Add New Artwork">
      <VBox.margin>
         <Insets left="5.0" />
      </VBox.margin></Label>
    <GridPane hgap="10" vgap="10">
        <Label text="Title:" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <TextField fx:id="titleField" GridPane.columnIndex="2" GridPane.rowIndex="0" />

        <Label text="Artist:" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <ComboBox fx:id="artistCombo" GridPane.columnIndex="2" GridPane.rowIndex="1" />

        <Label text="Year:" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <TextField fx:id="yearField" GridPane.columnIndex="2" GridPane.rowIndex="2" />

        <Label text="Type:" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <TextField fx:id="typeField" GridPane.columnIndex="2" GridPane.rowIndex="3" />

        <Label text="Dimensions:" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        <TextField fx:id="dimensionsField" GridPane.columnIndex="2" GridPane.rowIndex="4" />

        <Label text="Price:" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        <TextField fx:id="priceField" GridPane.columnIndex="2" GridPane.rowIndex="5" />

        <Label text="Description:" GridPane.columnIndex="1" GridPane.rowIndex="6" />
        <TextArea fx:id="descriptionArea" prefColumnCount="20" prefRowCount="4" GridPane.columnIndex="2" GridPane.rowIndex="6" />
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints maxWidth="249.0" minWidth="65.0" prefWidth="65.0" />
         <ColumnConstraints maxWidth="676.0" minWidth="154.0" prefWidth="676.0" />
         <ColumnConstraints maxWidth="338.0" minWidth="0.0" prefWidth="0.0" />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>
    <Button onAction="#handleAdd" text="Add Artwork">
      <VBox.margin>
         <Insets bottom="5.0" left="5.0" />
      </VBox.margin></Button>
</VBox>

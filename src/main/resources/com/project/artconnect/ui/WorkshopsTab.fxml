<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.WorkshopController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <TableView fx:id="workshopTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn"           text="Titre"          prefWidth="180" />
            <TableColumn fx:id="instructorColumn"      text="Formateur"      prefWidth="140" />
            <TableColumn fx:id="dateColumn"            text="Date"           prefWidth="140" />
            <TableColumn fx:id="priceColumn"           text="Prix (€)"       prefWidth="80" />
            <TableColumn fx:id="levelColumn"           text="Niveau"         prefWidth="100" />
            <TableColumn fx:id="maxParticipantsColumn" text="Places max"     prefWidth="90" />
            <TableColumn fx:id="remainingPlacesColumn" text="Places restantes"   prefWidth="90" />
            <TableColumn fx:id="durationColumn"        text="Durée (min)"     prefWidth="80" />
            <TableColumn fx:id="locationColumn"        text="Lieu"           prefWidth="150" />
        </columns>
    </TableView>

    <!-- Booking panel -->
    <TitledPane text="Réserver un atelier" expanded="true">
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <padding><Insets top="8" bottom="8" left="8" right="8"/></padding>
            <Label text="Membre :" />
            <ComboBox fx:id="memberCombo" prefWidth="200" />
            <Button fx:id="bookButton" text="Réserver" onAction="#handleBook" />
            <Label fx:id="bookingStatusLabel" style="-fx-text-fill: #2a7;" />
        </HBox>
    </TitledPane>
</VBox>
